{
  "mcpServers": {
    "taeys-hands": {
      "type": "stdio",
      "command": "python3",
      "args": ["/absolute/path/to/taeys-hands/server.py"],
      "cwd": "/absolute/path/to/taeys-hands",
      "env": {
        "DISPLAY": ":5",
        "TAEY_NODE_ID": "taeys-hands-claude-d5",
        "REDIS_HOST": "127.0.0.1",
        "REDIS_PORT": "6379",
        "NEO4J_URI": "bolt://localhost:7687",
        "TAEY_PLAN_TTL": "3600",
        "MCP_TOOL_TIMEOUT": "300"
      }
    },
    "isma-memory": {
      "type": "stdio",
      "command": "python3",
      "args": ["/absolute/path/to/embedding-server/isma/src/mcp_server.py"],
      "cwd": "/absolute/path/to/embedding-server",
      "env": {
        "PYTHONPATH": "/absolute/path/to/embedding-server",
        "WEAVIATE_URL": "http://localhost:8088",
        "NEO4J_URI": "bolt://localhost:7689",
        "REDIS_HOST": "127.0.0.1",
        "REDIS_PORT": "6379",
        "EMBEDDING_URL": "http://localhost:8091/v1/embeddings"
      }
    },
    "gitnexus": {
      "type": "stdio",
      "command": "gitnexus",
      "args": ["mcp"]
    }
  }
}
