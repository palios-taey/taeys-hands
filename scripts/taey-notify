#!/usr/bin/env python3
"""
Send a notification to any Claude instance's Redis inbox.

Messages are delivered via PostToolUse hook (active) or tmux fallback (idle).

Usage:
    taey-notify <target-node> "message"
    taey-notify <target-node> "ESCALATION: something broke" --type escalation
    taey-notify <target-node> "cycle done" --type heartbeat --priority low
"""
import argparse
import json
import os
import subprocess
import sys
import time

REDIS_HOST = os.environ.get('REDIS_HOST', '192.168.100.10')
REDIS_PORT = int(os.environ.get('REDIS_PORT', '6379'))

# Node ID → (ssh_host, tmux_session) for tmux fallback when target is idle.
# ssh_host=None means local machine.
_NODE_TMUX_MAP = {
    'taeys-hands': (None, 'taeys-hands'),
    'weaver':      (None, 'weaver'),
    'claude':      (None, 'claude'),
    'claw':        ('spark3', 'claw'),
    'thor-claude': ('thor', 'thor-claude'),
    'jetson-claude': ('jetson', 'jetson-claude'),
    'treasurer':   ('mira', 'treasurer'),
}


def detect_from_node():
    """Auto-detect sender identity."""
    explicit = os.environ.get('TAEY_NODE_ID')
    if explicit:
        return explicit
    try:
        result = subprocess.run(
            ['tmux', 'display-message', '-p', '#S'],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    except Exception:
        pass
    import socket
    return socket.gethostname()


def is_target_idle(r, target, threshold=15):
    """Check if target node is idle (safe for tmux injection)."""
    if r.exists(f"taey:{target}:tool_running"):
        return False
    last_str = r.get(f"taey:{target}:last_tool_activity")
    if not last_str:
        return True
    try:
        return time.time() - float(last_str) > threshold
    except (ValueError, TypeError):
        return True


def tmux_fallback(target, message):
    """Send message via tmux-send if target node mapping is known."""
    mapping = _NODE_TMUX_MAP.get(target)
    if not mapping:
        return False
    ssh_host, session = mapping
    try:
        if ssh_host:
            cmd = ['tmux-send', ssh_host, session, message]
        else:
            cmd = ['tmux-send', session, message]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
        return result.returncode == 0
    except Exception:
        return False


def main():
    parser = argparse.ArgumentParser(
        description="Send notification to a Claude instance's Redis inbox",
    )
    parser.add_argument('target', help='Target node ID (e.g. weaver, jetson-claude)')
    parser.add_argument('message', help='Message body')
    parser.add_argument('--type', '-t', default='message',
                        choices=['message', 'escalation', 'heartbeat', 'notification',
                                 'response_ready', 'command'],
                        help='Message type (default: message)')
    parser.add_argument('--priority', '-p', default='normal',
                        choices=['high', 'normal', 'low'],
                        help='Priority level (default: normal)')
    parser.add_argument('--from', dest='from_node', default=None,
                        help='Sender ID (auto-detected if omitted)')
    parser.add_argument('--redis-host', default=REDIS_HOST)
    parser.add_argument('--redis-port', type=int, default=REDIS_PORT)
    args = parser.parse_args()

    from_node = args.from_node or detect_from_node()

    if args.type == 'escalation' and args.priority == 'normal':
        args.priority = 'high'

    try:
        import redis
    except ImportError:
        print("ERROR: redis-py not installed. Run: pip install redis", file=sys.stderr)
        sys.exit(1)

    r = redis.Redis(
        host=args.redis_host, port=args.redis_port,
        decode_responses=True, socket_timeout=2,
    )

    try:
        r.ping()
    except Exception as e:
        print(f"ERROR: Cannot connect to Redis at {args.redis_host}:{args.redis_port}: {e}",
              file=sys.stderr)
        sys.exit(1)

    msg = json.dumps({
        "from": from_node,
        "type": args.type,
        "body": args.message,
        "timestamp": time.time(),
        "priority": args.priority,
    })

    # Always write to Redis inbox (primary channel)
    r.lpush(f"taey:{args.target}:inbox", msg)

    # If target is idle, also send via tmux to wake them
    if is_target_idle(r, args.target):
        prefix = "!!!" if args.type == 'escalation' else ""
        tmux_msg = f"[{prefix}NOTIFICATION from {from_node}]: {args.message}"
        if tmux_fallback(args.target, tmux_msg):
            print(f"OK: sent to {args.target} [{args.type}] from {from_node} (+ tmux fallback)")
        else:
            print(f"OK: sent to {args.target} [{args.type}] from {from_node} (Redis only, tmux failed)")
    else:
        print(f"OK: sent to {args.target} [{args.type}] from {from_node}")


if __name__ == '__main__':
    main()
