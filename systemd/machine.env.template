# machine.env — taey-display systemd unit configuration
# Per-machine. Copy to ~/.taey/machine.env and customize the per-display lines.
# Local file (not in repo): ~/.taey/machine.env
# This template (in repo): <repo>/systemd/machine.env.template

TAEY_MACHINE="<your-machine-name>"
TAEY_REDIS_HOST="127.0.0.1"
TAEY_REDIS_PORT="6379"

# Per-display: TAEY_DISPLAY_N="<role>:<firefox-profile-name>:<initial-url>"
# Role is a logical name (chatgpt, claude, gemini, grok, perplexity, x_twitter, etc.)
# Firefox profile lives at ~/.taey/profiles/<firefox-profile-name>
# Initial URL is loaded at display launch.
TAEY_DISPLAY_2="chatgpt:ff-profile-chatgpt:https://chatgpt.com/?temporary-chat=true"
TAEY_DISPLAY_3="claude:ff-profile-claude:https://claude.ai/new"
TAEY_DISPLAY_4="gemini:ff-profile-gemini:https://gemini.google.com/app"
TAEY_DISPLAY_5="grok:ff-profile-grok:https://grok.com/"
TAEY_DISPLAY_6="perplexity:ff-profile-perplexity:https://www.perplexity.ai/"

# Optional auxiliary displays: x_twitter, reddit, nvidia_forum, treasurer_gmail, upwork, etc.
# TAEY_DISPLAY_7="x_twitter:ff-profile-x-twitter:<AUXILIARY_URL>"
# TAEY_DISPLAY_11="reddit:ff-profile-reddit:<AUXILIARY_URL>"
# TAEY_DISPLAY_13="claude_cvp:ff-profile-claude-cvp:https://claude.ai/new"
