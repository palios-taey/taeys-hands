# Taey's Hands - Environment Configuration
# Copy this file to .env and adjust for your setup.
# All values below are the defaults — only set what you need to override.

# Redis (optional — server works without it)
# Used for: background monitor notifications, state persistence, control maps
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Neo4j (optional — server works without it)
# Used for: conversation history graph (sessions + messages)
NEO4J_URI=bolt://localhost:7687

# Optional webhook — called after each response extraction for custom post-processing
# HMM_STORE_URL=http://localhost:8095/hmm/store-response

# Instance identifier for Redis key scoping
# Auto-detected from: TAEY_NODE_ID > tmux session name > hostname
# TAEY_NODE_ID=my-instance

# X11 display (auto-detected by server, but useful for manual scripts)
# DISPLAY=:0
