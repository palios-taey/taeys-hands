# Taey's Hands - Environment Configuration
# Copy this file to .env and adjust for your setup.
# All values below are the defaults — only set what you need to override.

# ─── REQUIRED ───────────────────────────────────────────────────────
# Redis is REQUIRED. Server will NOT start without it.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── DISPLAY & IDENTITY ────────────────────────────────────────────
# CRITICAL: Each MCP server instance MUST have a unique DISPLAY + TAEY_NODE_ID.
# Collisions cause tab-switching interference between instances.
#
# Rule: one MCP server per DISPLAY, one unique TAEY_NODE_ID per instance.
# Convention: TAEY_NODE_ID = taeys-hands-{agent}-d{display_number}
#
# Example for Claude Code on display :5:
#   DISPLAY=:5
#   TAEY_NODE_ID=taeys-hands-claude-d5
#
# Auto-detected if not set: DISPLAY from lock files, TAEY_NODE_ID from tmux session name.
# DISPLAY=:5
# TAEY_NODE_ID=taeys-hands-claude-d5

# ─── TIMEOUTS & TTL ────────────────────────────────────────────────
# Tool execution timeout (seconds). Default 120, increase for slow platforms.
MCP_TOOL_TIMEOUT=120

# Plan TTL (seconds). Plans expire after this. Default 3600 (1 hour).
# Increase for long flows (Gemini Deep Research, multi-platform batches).
# Old default was 600 (10 min) — too short for real workflows.
TAEY_PLAN_TTL=3600

# Monitor cycle interval (seconds).
MONITOR_CYCLE_SEC=10

# ─── OPTIONAL: Neo4j ───────────────────────────────────────────────
# Conversation history graph. Server works without it.
NEO4J_URI=bolt://localhost:7687

# ─── OPTIONAL: Corpus & ISMA ──────────────────────────────────────
# Path to corpus directory for identity files and auto-ingestion.
# TAEY_CORPUS_PATH=~/data/corpus

# ISMA API for auto-ingestion of extracted responses.
# ISMA_API_URL=https://isma-api.taey.ai
# ISMA_API_KEY=your-key-here

# ─── OPTIONAL: Webhook ─────────────────────────────────────────────
# Called after each response extraction for custom post-processing.
# HMM_STORE_URL=http://localhost:8095/hmm/store-response
