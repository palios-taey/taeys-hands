# machine.env — Single source of truth for display/platform/infrastructure
# Copy to ~/.taey/machine.env on each machine and customize.
# Every launch/restart script sources this file. No more hard-coded tables.

# --- Machine Identity ---
TAEY_MACHINE="mira"              # "mira", "thor", "jetson", etc.
TAEY_REDIS_HOST="127.0.0.1"     # Redis host (Thor: 192.168.100.10)
TAEY_REDIS_PORT="6379"

# --- Display → Platform Mappings ---
# Format: TAEY_DISPLAY_{N}="platform:profile:url"
# Scripts parse these to know what runs where.
# Only define displays that exist on THIS machine.

# Example (Mira):
# TAEY_DISPLAY_2="chatgpt:ff-profile-mira-chatgpt:https://chatgpt.com/?temporary-chat=true"
# TAEY_DISPLAY_3="claude:ff-profile-mira-claude:https://claude.ai/new"
# TAEY_DISPLAY_4="gemini:ff-profile-mira-gemini:https://gemini.google.com/app"
# TAEY_DISPLAY_5="grok:ff-profile-mira-grok:https://grok.com/"
# TAEY_DISPLAY_6="perplexity:ff-profile-mira-perplexity:https://www.perplexity.ai/"

# Example (Thor):
# TAEY_DISPLAY_6="gemini:ff-profile-gemini:https://gemini.google.com/app"
# TAEY_DISPLAY_7="grok:ff-profile-grok:https://grok.com/"
# TAEY_DISPLAY_9="perplexity:ff-profile-perplexity:https://www.perplexity.ai/"
# TAEY_DISPLAY_11="chatgpt:ff-profile-chatgpt:https://chatgpt.com/?temporary-chat=true"

# --- Naming Conventions (enforced by scripts) ---
# tmux sessions: {bottype}-{platform}  (e.g., hmm-chatgpt, dpo-chatgpt)
# profiles:      /tmp/{profile}         (profile field from TAEY_DISPLAY_N)
# bus files:     /tmp/a11y_bus_:{N}     (written by restart scripts)
# D-Bus:         Isolated per display   (dbus-launch, NOT shared bus)
