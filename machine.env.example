# machine.env - local display/platform/infrastructure configuration
#
# Copy to ~/.taey/machine.env, customize, then run:
#   chmod 600 ~/.taey/machine.env
#   ./scripts/install_machine_displays.sh

TAEY_MACHINE="<your-machine-name>"
TAEY_REPO="<absolute-path-to-taeys-hands>"
TAEY_REDIS_HOST="127.0.0.1"
TAEY_REDIS_PORT="6379"

TAEY_FIREFOX_BIN="<absolute-path-to-firefox-binary>"
TAEY_AT_SPI_BUS_LAUNCHER="/usr/libexec/at-spi-bus-launcher"
TAEY_AT_SPI_REGISTRYD="/usr/libexec/at-spi2-registryd"
TAEY_USE_SOFTWARE_GL="1"

TAEY_VNC_PASSWORD="<local-vnc-password>"

# Format: TAEY_DISPLAY_N="platform:profile:url"
# Only define displays that exist on this machine. A platform may appear on
# multiple rows when several authenticated profiles are available; profile names
# must remain unique.
TAEY_DISPLAY_2="chatgpt:ff-profile-chatgpt:https://chatgpt.com/"
TAEY_DISPLAY_3="claude:ff-profile-claude:https://claude.ai/new"
TAEY_DISPLAY_4="gemini:ff-profile-gemini:https://gemini.google.com/app"
TAEY_DISPLAY_5="grok:ff-profile-grok:https://grok.com/"
TAEY_DISPLAY_6="perplexity:ff-profile-perplexity:https://www.perplexity.ai/"
# Optional second Gemini profile for Pro/non-deep pooled parallelism.
# Gemini deep modes route to TAEY_GEMINI_PRIMARY_DISPLAY, defaulting to the
# first configured Gemini row.
# TAEY_GEMINI_PRIMARY_DISPLAY=":4"
# TAEY_DISPLAY_22="gemini:ff-profile-gemini-2:https://gemini.google.com/app"
