# --- INFRASTRUCTURE STANDARDS ---
REDIS_HOST="127.0.0.1"  # On Thor, change this to "192.168.100.10"

# --- DISPLAY MAPPINGS (platform:display_num) ---
# Mira: displays :2-:6
DISPLAYS_MIRA="chatgpt:2,claude:3,gemini:4,grok:5,perplexity:6"

# Thor: displays :4-:13
DISPLAYS_THOR="perplexity:4,gemini:6,grok:7,claude:8,perplexity:9,claude:10,chatgpt:11,grok:12,chatgpt:13"

# --- NAMING CONVENTIONS (Enforced in scripts) ---
# PROFILE: /tmp/ff-profile-${MACHINE}-${PLATFORM}-${DISPLAY_NUM}
# TMUX:    ${BOT_TYPE}-${PLATFORM}-${DISPLAY_NUM}
# BUS:     /tmp/a11y_bus_:${DISPLAY_NUM}
