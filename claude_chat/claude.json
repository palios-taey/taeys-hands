{
  "version": "1.0.0",
  "lastUpdated": "2025-11-30",
  "platform": "claude",
  "selectors": {
    "chatInput": "[contenteditable=\"true\"]",
    "sendButton": "button[type=\"submit\"]",
    "modelSelector": "[data-testid=\"model-selector-dropdown\"]",
    "modelMenuItem": "div[role=\"menuitem\"]",
    "plusMenu": "[data-testid=\"input-menu-plus\"]",
    "uploadMenuItem": "text=\"Upload a file\"",
    "downloadButton": "button[aria-label=\"Download\"]",
    "thinkingIndicator": "[data-testid=\"thinking-indicator\"]",
    "responseContainer": "[data-testid=\"assistant-message\"]",
    "toolsMenu": "#input-tools-menu-trigger",
    "researchToggle": "button:has-text(\"Research\")",
    "webSearchToggle": "button:has-text(\"Web search\")",
    "extendedThinkingToggle": "button:has-text(\"Extended thinking\")",
    "artifactCard": "[data-testid=\"artifact-card\"]",
    "artifactMenuDropdown": "[data-testid=\"artifact-menu\"]",
    "downloadAsMarkdown": "text=\"Download as Markdown\""
  },
  "fallbacks": {
    "chatInput": [
      "[contenteditable=\"true\"]",
      "div[role=\"textbox\"]",
      "[data-testid=\"composer-input\"]"
    ],
    "modelSelector": [
      "[data-testid=\"model-selector-dropdown\"]",
      "button[aria-label*=\"Model\"]"
    ],
    "responseContainer": [
      "[data-testid=\"assistant-message\"]",
      "[data-message-author-role=\"assistant\"]",
      ".assistant-message"
    ]
  }
}
