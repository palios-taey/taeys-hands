{
  "version": "1.0.0",
  "lastUpdated": "2025-11-30",
  "platform": "perplexity",
  "selectors": {
    "chatInput": "textarea",
    "sendButton": "button[aria-label=\"Send\"]",
    "modeRadioGroup": "div[role=\"radiogroup\"]",
    "searchMode": "button[role=\"radio\"][value=\"search\"]",
    "researchMode": "button[role=\"radio\"][value=\"research\"]",
    "labsMode": "button[role=\"radio\"][value=\"studio\"]",
    "attachButton": "button[data-testid=\"attach-files-button\"]",
    "localFilesMenuItem": "div[role=\"menuitem\"]:has-text(\"Local files\")",
    "responseContainer": "div.prose.dark\\:prose-invert.inline.leading-relaxed"
  },
  "fallbacks": {
    "chatInput": [
      "textarea",
      "[contenteditable=\"true\"]",
      "[data-testid=\"search-input\"]"
    ],
    "attachButton": [
      "button[data-testid=\"attach-files-button\"]",
      "button[aria-label*=\"attach\" i]",
      "button:has(svg[class*=\"paperclip\"])"
    ],
    "responseContainer": [
      "div.prose.dark\\:prose-invert.inline.leading-relaxed",
      "[class*=\"answer-content\"]",
      "[class*=\"response-text\"]"
    ]
  },
  "quirks": {
    "noModelSelection": true,
    "modeViaRadioButtons": true,
    "specialResponseSelector": "CRITICAL: Use specific parent selector 'div.prose.dark\\:prose-invert.inline.leading-relaxed' not generic [class*=\"prose\"] which matches child elements"
  },
  "modes": {
    "search": {
      "value": "search",
      "testid": "search-mode-search",
      "description": "Standard search"
    },
    "research": {
      "value": "research",
      "testid": "search-mode-research",
      "description": "Pro Search - deeper research"
    },
    "studio": {
      "value": "studio",
      "testid": "search-mode-studio",
      "description": "Labs - experimental features"
    }
  }
}
