{
  "version": "1.0.0",
  "platform": "chatgpt",
  "url": "https://chatgpt.com",
  "selectors": {
    "model_selector": {
      "primary": "button[data-testid=\"model-switcher-dropdown-button\"]",
      "fallback": "button[aria-label*=\"Model selector\"]",
      "description": "Main model selector dropdown button"
    },
    "attach_button": {
      "primary": "button[data-testid=\"composer-plus-btn\"]",
      "fallback": "button[aria-label=\"Add files and more\"]",
      "description": "Plus button that opens attachment/modes menu"
    },
    "send_button": {
      "primary": "button[data-testid=\"send-button\"]",
      "fallback": "button[aria-label*=\"Send\"]",
      "description": "Send message button in composer"
    },
    "message_input": {
      "primary": "div[contenteditable=\"true\"]",
      "description": "Message input contenteditable div in composer area"
    },
    "new_chat_button": {
      "primary": "button[data-testid=\"new-chat-button\"]",
      "fallback": "a[href*=\"/\"]",
      "description": "New chat button to start fresh conversation"
    },
    "menu_item_attach_files": {
      "primary": "text=Add photos & files",
      "description": "Menu item for attaching files (text-based selection)"
    },
    "menu_item_deep_research": {
      "primary": "text=Deep research",
      "description": "Menu item for Deep research mode"
    },
    "menu_item_agent_mode": {
      "primary": "text=Agent mode",
      "description": "Menu item for Agent mode"
    },
    "menu_item_web_search": {
      "primary": "text=Web search",
      "description": "Menu item for Web search"
    },
    "model_auto": {
      "primary": "text=Auto",
      "description": "Auto model selection in dropdown"
    },
    "model_instant": {
      "primary": "text=Instant",
      "description": "Instant model selection in dropdown"
    },
    "model_thinking": {
      "primary": "text=Thinking",
      "description": "Thinking model selection in dropdown"
    },
    "model_pro": {
      "primary": "text=Pro",
      "description": "Pro model selection in dropdown"
    },
    "model_legacy_submenu": {
      "primary": "text=Legacy",
      "description": "Legacy submenu for older models"
    },
    "model_gpt4o": {
      "primary": "text=GPT-4o",
      "description": "GPT-4o in Legacy submenu"
    }
  }
}
