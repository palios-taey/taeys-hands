{
  "browser": {
    "debuggingPort": 9222,
    "userDataDir": "/Users/REDACTED/Library/Application Support/Google/Chrome",
    "executablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
  },
  "interfaces": {
    "claude": {
      "url": "https://claude.ai",
      "selectors": {
        "chatInput": "[contenteditable='true']",
        "sendButton": "button[type='submit']",
        "responseContainer": ".prose"
      }
    },
    "chatgpt": {
      "url": "https://chat.openai.com",
      "selectors": {
        "chatInput": "#prompt-textarea",
        "sendButton": "button[data-testid='send-button']",
        "responseContainer": ".markdown",
        "modelSelector": "[data-testid='model-switcher-dropdown-button']",
        "modeMenuButton": "[data-testid='composer-plus-btn']",
        "fileAttachment": "[data-testid='composer-plus-btn']"
      },
      "models": ["5.1 Pro", "4o", "4o mini", "o1", "o1-mini"],
      "modes": ["Deep research", "Agent mode", "Study and learn", "Web search"]
    },
    "gemini": {
      "url": "https://gemini.google.com",
      "selectors": {
        "chatInput": "textarea",
        "sendButton": "button[aria-label='Send']",
        "responseContainer": ".response-content"
      }
    },
    "grok": {
      "url": "https://grok.com",
      "selectors": {
        "chatInput": "textarea",
        "sendButton": "button[type='submit']",
        "responseContainer": "div.response-content-markdown"
      }
    },
    "perplexity": {
      "url": "https://perplexity.ai",
      "selectors": {
        "chatInput": "textarea",
        "sendButton": "button[type='submit']",
        "responseContainer": "[class*='prose']"
      }
    }
  },
  "mimesis": {
    "typing": {
      "baseDelayMs": 50,
      "variationMs": 30,
      "burstProbability": 0.1
    },
    "mouse": {
      "bezierSteps": 20,
      "speedVariation": 0.3
    }
  }
}
